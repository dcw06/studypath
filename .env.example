SECRET_KEY=change-me-to-a-long-random-string

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth — Facebook (optional)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Database path (default: game.db in the project root)
